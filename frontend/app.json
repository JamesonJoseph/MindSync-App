{
  "expo": {
    "name": "MindSync",
    "slug": "MindSync_App",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/mindlogo.png",
    "scheme": "mindsyncapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mindsync.app"
    },
    "android": {
      "package": "com.mindsync.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/mindlogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#00E0C6",
          "dark": {
            "backgroundColor": "#00E0C6",
            "image": "./assets/images/mindlogo.png"
          }
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow MindSync to access your microphone for voice analysis."
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "assetBundlePatterns": [
      "app/assets/avatar/*",
      "assets/avatar/*"
    ]
  }
}
